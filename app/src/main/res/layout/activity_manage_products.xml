<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_screen"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    tools:context=".ManageProductsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage Product Details"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/px_primary"
            tools:ignore="HardcodedText" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add and manage PrintXpress printing products"
            android:textSize="15sp"
            android:textColor="@color/px_muted"
            android:layout_marginTop="4dp"
            tools:ignore="HardcodedText" />

        <EditText
            android:id="@+id/etProductName"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Product Name"
            android:padding="14dp"
            android:background="@drawable/bg_search_box"
            android:inputType="text"
            android:autofillHints="none"
            android:layout_marginTop="22dp"
            tools:ignore="HardcodedText" />

        <EditText
            android:id="@+id/etProductCategory"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Category Name"
            android:padding="14dp"
            android:background="@drawable/bg_search_box"
            android:inputType="text"
            android:autofillHints="none"
            android:layout_marginTop="12dp"
            tools:ignore="HardcodedText" />

        <EditText
            android:id="@+id/etProductDescription"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Product Description"
            android:gravity="top"
            android:padding="14dp"
            android:background="@drawable/bg_search_box"
            android:inputType="textMultiLine"
            android:autofillHints="none"
            android:layout_marginTop="12dp"
            tools:ignore="HardcodedText" />

        <EditText
            android:id="@+id/etBasePrice"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Base Price"
            android:padding="14dp"
            android:background="@drawable/bg_search_box"
            android:inputType="number"
            android:autofillHints="none"
            android:layout_marginTop="12dp"
            tools:ignore="HardcodedText" />

        <EditText
            android:id="@+id/etMaterial"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Material"
            android:padding="14dp"
            android:background="@drawable/bg_search_box"
            android:inputType="text"
            android:autofillHints="none"
            android:layout_marginTop="12dp"
            tools:ignore="HardcodedText" />

        <EditText
            android:id="@+id/etSize"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Size"
            android:padding="14dp"
            android:background="@drawable/bg_search_box"
            android:inputType="text"
            android:autofillHints="none"
            android:layout_marginTop="12dp"
            tools:ignore="HardcodedText" />

        <Button
            android:id="@+id/btnAddProduct"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Add Product"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/bg_primary_button"
            android:elevation="3dp"
            android:layout_marginTop="18dp"
            tools:ignore="HardcodedText" />

        <Button
            android:id="@+id/btnBackAdminFromProducts"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Back to Admin Dashboard"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/bg_primary_button"
            android:elevation="3dp"
            android:layout_marginTop="12dp"
            tools:ignore="HardcodedText" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Available Products"
            android:textSize="19sp"
            android:textStyle="bold"
            android:textColor="@color/px_text"
            android:layout_marginTop="24dp"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:id="@+id/productsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>