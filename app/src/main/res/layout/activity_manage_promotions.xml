<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage Promotions"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/px_primary"
            android:layout_marginTop="25dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create and manage seasonal offers"
            android:textSize="15sp"
            android:textColor="@color/px_muted"
            android:layout_marginTop="4dp" />

        <EditText
            android:id="@+id/etPromotionTitle"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Promotion Title"
            android:padding="14dp"
            android:background="@android:drawable/edit_text"
            android:inputType="text"
            android:layout_marginTop="22dp" />

        <EditText
            android:id="@+id/etPromotionDescription"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Promotion Description"
            android:gravity="top"
            android:padding="14dp"
            android:background="@android:drawable/edit_text"
            android:inputType="textMultiLine"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/etDiscount"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Discount Percentage"
            android:padding="14dp"
            android:background="@android:drawable/edit_text"
            android:inputType="number"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/etValidUntil"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Valid Until - Example: 2026-05-30"
            android:padding="14dp"
            android:background="@android:drawable/edit_text"
            android:inputType="date"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnAddPromotion"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Add Promotion"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:background="@drawable/bg_primary_button"
            android:elevation="3dp"
            android:layout_marginTop="18dp" />

        <Button
            android:id="@+id/btnRefreshPromotions"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Refresh Promotions"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:background="@drawable/bg_primary_button"
            android:elevation="3dp"
            android:layout_marginTop="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Available Promotions"
            android:textSize="19sp"
            android:textStyle="bold"
            android:textColor="@color/px_text"
            android:layout_marginTop="24dp" />

        <LinearLayout
            android:id="@+id/promotionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnBackAdminFromPromotions"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Back to Admin Dashboard"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:background="@drawable/bg_primary_button"
            android:elevation="3dp"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="25dp" />

    </LinearLayout>
</ScrollView>
