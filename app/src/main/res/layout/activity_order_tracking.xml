<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_screen"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    tools:context=".OrderTrackingActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Order Tracking"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/px_primary"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/tvOrderId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Order ID"
            android:textSize="14sp"
            android:textColor="@color/px_muted"
            android:layout_marginTop="8dp"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/tvTrackingDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading order details..."
            android:textSize="15sp"
            android:textColor="@color/px_text"
            android:lineSpacingExtra="6dp"
            android:padding="18dp"
            android:background="@drawable/bg_white_card"
            android:elevation="3dp"
            android:layout_marginTop="20dp"
            tools:ignore="HardcodedText" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Order Status Timeline"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/px_text"
            android:layout_marginTop="24dp"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/tvTimeline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="* Pending&#10;- Processing&#10;- Ready for Pickup / Delivery&#10;- Complete&#10;- Cancelled"
            android:textSize="16sp"
            android:textColor="@color/px_primary"
            android:lineSpacingExtra="10dp"
            android:padding="18dp"
            android:background="@drawable/bg_white_card"
            android:elevation="3dp"
            android:layout_marginTop="12dp"
            tools:ignore="HardcodedText" />

        <Button
            android:id="@+id/btnBackHomeTracking"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Back to Home"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_primary_button"
            android:elevation="3dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="24dp"
            tools:ignore="HardcodedText" />
</LinearLayout>
</ScrollView>
