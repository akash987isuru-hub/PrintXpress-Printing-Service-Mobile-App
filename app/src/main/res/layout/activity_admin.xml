<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_screen"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    tools:context=".AdminActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_white_card"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welcome,"
                android:textColor="@color/px_muted"
                android:textSize="15sp"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Admin / Staff Dashboard"
                android:textColor="@color/px_text"
                android:textSize="26sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Manage products, orders, customers, promotions and support"
                android:textColor="@color/px_muted"
                android:textSize="14sp"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"
            android:text="Admin Tools"
            android:textColor="@color/px_text"
            android:textSize="21sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/cardManageCategories"
                style="@style/AdminGridCard"
                android:layout_marginEnd="6dp">
                <ImageView style="@style/AdminGridImageIcon" android:src="@drawable/ic_category" android:contentDescription="Categories icon" />
                <TextView style="@style/AdminGridTitle" android:text="Categories" tools:ignore="HardcodedText" />
                <TextView style="@style/AdminGridSubtitle" android:text="Add and delete categories" tools:ignore="HardcodedText" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardManageProducts"
                style="@style/AdminGridCard"
                android:layout_marginStart="6dp">
                <ImageView style="@style/AdminGridImageIcon" android:src="@drawable/ic_products" android:contentDescription="Products icon" />
                <TextView style="@style/AdminGridTitle" android:text="Products" tools:ignore="HardcodedText" />
                <TextView style="@style/AdminGridSubtitle" android:text="Prices, sizes, materials" tools:ignore="HardcodedText" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/cardReviewDesigns"
                style="@style/AdminGridCard"
                android:layout_marginEnd="6dp">
                <ImageView style="@style/AdminGridImageIcon" android:src="@drawable/ic_designs" android:contentDescription="Designs icon" />
                <TextView style="@style/AdminGridTitle" android:text="Designs" tools:ignore="HardcodedText" />
                <TextView style="@style/AdminGridSubtitle" android:text="Review uploaded files" tools:ignore="HardcodedText" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardUpdateOrderStatus"
                style="@style/AdminGridCard"
                android:layout_marginStart="6dp">
                <ImageView style="@style/AdminGridImageIcon" android:src="@drawable/ic_orders" android:contentDescription="Orders icon" />
                <TextView style="@style/AdminGridTitle" android:text="Orders" tools:ignore="HardcodedText" />
                <TextView style="@style/AdminGridSubtitle" android:text="Update order status" tools:ignore="HardcodedText" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/cardManagePromotions"
                style="@style/AdminGridCard"
                android:layout_marginEnd="6dp">
                <ImageView style="@style/AdminGridImageIcon" android:src="@drawable/ic_promotions" android:contentDescription="Promotions icon" />
                <TextView style="@style/AdminGridTitle" android:text="Promotions" tools:ignore="HardcodedText" />
                <TextView style="@style/AdminGridSubtitle" android:text="Offers and discounts" tools:ignore="HardcodedText" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardSupportQueries"
                style="@style/AdminGridCard"
                android:layout_marginStart="6dp">
                <ImageView style="@style/AdminGridImageIcon" android:src="@drawable/ic_support" android:contentDescription="Support icon" />
                <TextView style="@style/AdminGridTitle" android:text="Support" tools:ignore="HardcodedText" />
                <TextView style="@style/AdminGridSubtitle" android:text="Customer chat inbox" tools:ignore="HardcodedText" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:id="@+id/cardViewCustomers"
                style="@style/AdminGridCard"
                android:layout_marginEnd="6dp">
                <ImageView style="@style/AdminGridImageIcon" android:src="@drawable/ic_customers" android:contentDescription="Customers icon" />
                <TextView style="@style/AdminGridTitle" android:text="Customers" tools:ignore="HardcodedText" />
                <TextView style="@style/AdminGridSubtitle" android:text="View customer details" tools:ignore="HardcodedText" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardViewRevenue"
                style="@style/AdminGridCard"
                android:layout_marginStart="6dp">
                <ImageView style="@style/AdminGridImageIcon" android:src="@drawable/ic_revenue" android:contentDescription="Revenue icon" />
                <TextView style="@style/AdminGridTitle" android:text="Revenue" tools:ignore="HardcodedText" />
                <TextView style="@style/AdminGridSubtitle" android:text="Sales and orders" tools:ignore="HardcodedText" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnAdminLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_danger_button"
            android:elevation="3dp"
            android:text="Logout"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />

    </LinearLayout>
</ScrollView>
