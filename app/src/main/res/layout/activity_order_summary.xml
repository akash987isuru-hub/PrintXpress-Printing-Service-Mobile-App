<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Order Summary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/px_primary"
            android:layout_marginTop="25dp" />

        <TextView
            android:id="@+id/tvSummaryDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Order details"
            android:textSize="15sp"
            android:textColor="@color/px_text"
            android:lineSpacingExtra="6dp"
            android:padding="16dp"
            android:background="@drawable/bg_white_card"
            android:layout_marginTop="20dp" />

        <TextView
            android:id="@+id/tvSummaryTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total Payable: Rs. 0"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FF9800"
            android:gravity="center"
            android:layout_marginTop="20dp" />

        <Button
            android:id="@+id/btnConfirmOrder"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Proceed to Payment"
            android:textColor="@color/white"
            android:background="@drawable/bg_primary_button"
            android:layout_marginTop="28dp" />

        <Button
            android:id="@+id/btnBackDelivery"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Back to Delivery"
            android:textColor="@color/white"
            android:background="@drawable/bg_primary_button"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="25dp" />

    </LinearLayout>
</ScrollView>
