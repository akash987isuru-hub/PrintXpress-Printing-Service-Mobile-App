<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="28dp">

        <ImageView
            android:id="@+id/imgSplashLogo"
            android:layout_width="132dp"
            android:layout_height="132dp"
            android:background="@drawable/bg_splash_logo"
            android:contentDescription="PrintXpress logo"
            android:padding="18dp"
            android:scaleType="fitCenter"
            android:src="@drawable/images" />

        <TextView
            android:id="@+id/tvSplashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="PrintXpress"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSplashSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Fast · Creative · Professional Printing"
            android:textColor="#DDEBFF"
            android:textSize="15sp" />

        <ProgressBar
            android:id="@+id/progressSplash"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:indeterminateTint="#FFFFFF" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="26dp"
        android:gravity="center"
        android:text="Powered by PrintXpress"
        android:textColor="#99FFFFFF"
        android:textSize="12sp" />

</FrameLayout>
